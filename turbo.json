{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    ".env*"
  ],
  "globalEnv": [
    "HOST",
    "PORT",
    "MONGODB_URI",
    "REDIS_URL",
    "AI_API_URL",
    "AI_API_KEY",
    "AI_MODEL",
    "FRONTEND_ORIGIN",
    "NEXT_PUBLIC_APP_URL",
    "NEXT_PUBLIC_API_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        ".next/**",
        "dist/**"
      ]
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "worker": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "cache": false,
      "persistent": true
    },
    "start:worker": {
      "cache": false,
      "persistent": true
    }
  }
}
