{
  "name": "vedaai_task",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo run dev worker --filter=@vedaai/web --filter=@vedaai/backend",
    "dev:web": "turbo run dev --filter=@vedaai/web",
    "dev:backend": "turbo run dev --filter=@vedaai/backend",
    "build": "turbo run build --filter=@vedaai/web --filter=@vedaai/backend",
    "start": "turbo run start --filter=@vedaai/web --filter=@vedaai/backend",
    "start:worker": "turbo run start:worker --filter=@vedaai/backend",
    "lint": "turbo run lint --filter=@vedaai/web --filter=@vedaai/backend",
    "worker": "turbo run worker --filter=@vedaai/backend"
  },
  "devDependencies": {
    "turbo": "^2.8.20"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
